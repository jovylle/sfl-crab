SFL_API_KEY=
SFL_API_KEY_DEV=

# Vite-only dev (`npm run dev:vite`): proxy /api/* (default beta.d1g.uk)
# VITE_API_PROXY_TARGET=https://beta.d1g.uk
# VITE_API_PROXY_TARGET=http://localhost:8888

# Dig-day + hub-auth proxy → SFL Digging Hub (set in Netlify site env, not Vite)
HUB_API_BASE=https://beta.api.d1g.uk
HUB_WRITE_SECRET=

# Hub must expose /v1/auth/* (Google OAuth, email OTP, /me). No passwords.

# Optional: hub replay UI base for link fallback if API returns id only (Vite build)
# VITE_HUB_UI_BASE=https://beta.hub.d1g.uk

# Menu → Support d1g.uk (Ko-fi). Set in Netlify build env per site.
# VITE_KOFI_URL=https://ko-fi.com/yourusername