# Sunflower Land API Configuration
# Get your API key from: https://sunflower-land.com/play
# Format: sfl.<YOUR_KEY>
# This is used by the Netlify function (server-side only)
SFL_API_KEY=sfl.YOUR_API_KEY_HERE

# Test / dev API (api-dev.sunflower-land.com) — separate key from production
SFL_API_KEY_DEV=sfl.YOUR_TEST_API_KEY_HERE
HUB_API_BASE
HUB_WRITE_SECRET