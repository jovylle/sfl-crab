# Sunflower Land API Configuration
# Get your API key from: https://sunflower-land.com/play
# Format: sfl.<YOUR_KEY>
# This is used by the Netlify function (server-side only)
SFL_API_KEY=sfl.YOUR_API_KEY_HERE

# Test / dev API (api-dev.sunflower-land.com) — separate key from production
SFL_API_KEY_DEV=sfl.YOUR_TEST_API_KEY_HERE
HUB_API_BASE
HUB_WRITE_SECRET

# /admin page — server-side only (Netlify function checks this)
ADMIN_PASSWORD=choose-a-long-random-password

# ProjectMate embed configuration (client-side)
VITE_PROJECTMATE_PROJECT_ID=sfl-crab
VITE_PROJECTMATE_APP_URL=https://projectmate.uft1.com/overlay/
# Optional: override feedback API base (default: {site}/api/projectmate)
VITE_PROJECTMATE_FEEDBACK_ENDPOINT=
# Optional: custom API base instead of /api/projectmate
VITE_PROJECTMATE_ISSUES_ENDPOINT=
# Web3Forms access key — server-side only (Netlify function); not bundled in client
WEB3FORMS_ACCESS_KEY=
# Legacy alias read by projectmate-feedback function if WEB3FORMS_ACCESS_KEY unset
VITE_PROJECTMATE_WEB3FORMS_KEY=